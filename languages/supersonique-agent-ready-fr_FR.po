# ============================================================
# Section ⓪ Mode
# ============================================================

msgid "Static = Apache files / Dynamic = WP rewrites"
msgstr "Static = fichiers Apache / Dynamic = rewrites WP"

msgid "Mode"
msgstr "Mode"

msgid "Writes real JSON files in <code>.well-known/</code>. Served directly by Apache, zero PHP, Cloudflare-friendly. <em>Recommended.</em>"
msgstr "Écrit de vrais fichiers JSON dans <code>.well-known/</code>. Servis directement par Apache, zéro PHP, Cloudflare-friendly. <em>Recommandé.</em>"

msgid "WordPress rewrite rules + PHP. Only use this if static mode cannot write to <code>.well-known/</code> (permissions)."
msgstr "Rewrite rules WordPress + PHP. À n’utiliser que si le mode static ne peut pas écrire dans <code>.well-known/</code> (permissions)."

msgid "Files are regenerated automatically on every save. On plugin deactivation, static files are removed."
msgstr "Les fichiers sont régénérés automatiquement à chaque sauvegarde. À la désactivation du plugin, les fichiers statiques sont supprimés."

