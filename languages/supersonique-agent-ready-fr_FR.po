msgstr "Un header par ligne. Exemple : <code>&lt;/api&gt;; rel=\"service-doc\"</code>"

# ============================================================
# Section ② robots.txt
# ============================================================

msgid "Bot Access Control 50→100"
msgstr "Bot Access Control 50→100"

msgid "AI bot rules"
msgstr "Règles AI bots"

msgid "Add <code>User-agent</code> directives for AI crawlers"
msgstr "Ajouter des directives <code>User-agent</code> pour les crawlers IA"

msgid "Allow / Block"
msgstr "Autoriser / Bloquer"

msgid "Allow (<code>Disallow:</code> empty)"
msgstr "Autoriser (<code>Disallow:</code> vide)"

msgid "Block (<code>Disallow: /</code>)"
msgstr "Bloquer (<code>Disallow: /</code>)"

msgid "Bot list"
msgstr "Liste des bots"

msgid "One bot per line."
msgstr "Un bot par ligne."

msgid "Add the <code>Content-Signal</code> directive to robots.txt"
msgstr "Ajouter la directive <code>Content-Signal</code> dans robots.txt"

msgid "Training AI models on the content"
msgstr "Entraînement de modèles IA sur le contenu"

msgid "Indexing in AI search engines"
msgstr "Indexation dans les moteurs de recherche IA"

msgid "Use as agent context (RAG…)"
msgstr "Utilisation comme contexte d’agent (RAG…)"

msgid "yes — allowed"
msgstr "oui — autorisé"

msgid "no — denied"
msgstr "non — refusé"

