# Admin menu and page header
# ============================================================

msgid "Agent Ready"
msgstr "Agent Ready"

#. translators: %s is the site home URL
msgid "Configure agent-readiness signals for %s"
msgstr "Configure les signaux d’agent-readiness pour %s"

msgid "View isitagentready.com score ↗"
msgstr "Voir le score isitagentready.com ↗"

msgid "Settings saved. Remember to <strong>purge your caches</strong> (Cloudflare Purge Everything + any WordPress caching plugin)."
msgstr "Paramètres sauvegardés. Pense à <strong>vider les caches</strong> (Cloudflare Purge Everything + plugin de cache WordPress)."

