#. Default skill description for "search"
#. translators: %s is the site name
msgid "Search %s articles and pages by keyword."
msgstr "Recherche dans les articles et pages de %s par mot-clé."

#. Default skill description for "sitemap"
#. translators: %s is the site name
msgid "Full XML sitemap listing all public pages and posts of %s."
msgstr "Sitemap XML complet listant toutes les pages et articles publics de %s."

msgid "Search keywords"
msgstr "Mots-clés de recherche"

#. WebMCP tool: search description
#. translators: %s is the site name
msgid "Search %s content by keyword."
msgstr "Recherche dans le contenu de %s par mot-clé."

#. WebMCP tool: sitemap description
#. translators: %s is the site name
msgid "Get the full XML sitemap URL of %s."
msgstr "Récupère l’URL du sitemap XML complet de %s."

#. WebMCP tool: homepage description
#. translators: 1: site name, 2: site description
msgid "Get the homepage of %1$s. %2$s"
msgstr "Récupère la page d’accueil de %1$s. %2$s"

