msgstr "Laisse vide pour utiliser %s par défaut."

# ============================================================
# Section ④ Agent Skills Index
# ============================================================

msgid "Agent Skills Index"
msgstr "Agent Skills Index"

msgid "RFC v0.2.0 — API/MCP Discovery +1"
msgstr "RFC v0.2.0 — API/MCP Discovery +1"

msgid "Serve <code>/.well-known/agent-skills/index.json</code>"
msgstr "Servir <code>/.well-known/agent-skills/index.json</code>"

msgid "Built-in skills: <strong>search</strong> and <strong>sitemap</strong> with a valid <code>inputSchema</code> (v0.2.0). Extensible via <code>add_filter('supup_agent_skills', ...)</code>"
msgstr "Skills inclus : <strong>search</strong> et <strong>sitemap</strong> avec un <code>inputSchema</code> valide (v0.2.0). Extensible via <code>add_filter('supup_agent_skills', ...)</code>"

# ============================================================
# Section ④b Markdown Negotiation
# ============================================================

msgid "Content 0→100"
msgstr "Content 0→100"

msgid "Respond in <code>text/markdown</code> when the agent sends <code>Accept: text/markdown</code>"
msgstr "Répondre en <code>text/markdown</code> quand l’agent envoie <code>Accept: text/markdown</code>"

msgid "On-the-fly HTML → Markdown conversion (headings, links, lists, bold/italic). Adds <code>Vary: Accept</code>."
msgstr "Conversion à la volée HTML → Markdown (titres, liens, listes, gras/italique). Ajoute <code>Vary: Accept</code>."

# ============================================================
# Section ④c Web Bot Auth
# ============================================================

msgid "Web Bot Auth"
msgstr "Web Bot Auth"

msgid "Cloudflare / HTTP Message Signatures"
msgstr "Cloudflare / HTTP Message Signatures"

msgid "Serve <code>/.well-known/http-message-signatures-directory</code> (empty directory)"
msgstr "Servir <code>/.well-known/http-message-signatures-directory</code> (annuaire vide)"

# ============================================================
# Section ⑤ OAuth Protected Resource
# ============================================================

msgid "RFC 9728 — optional for brochure sites"
msgstr "RFC 9728 — optionnel pour sites vitrines"

msgid "Serve <code>/.well-known/oauth-protected-resource</code> (minimal endpoint)"
msgstr "Servir <code>/.well-known/oauth-protected-resource</code> (endpoint minimaliste)"

msgid "Enable only if your site exposes protected APIs. For a brochure site the endpoint is minimal but enough to pass the check."
msgstr "Active uniquement si ton site expose des APIs protégées. Pour un site vitrine, cet endpoint est minimaliste mais suffit à passer le check."

# ============================================================
# Section ⑤b OAuth/OIDC Discovery
# ============================================================

msgid "RFC 8414 / OpenID Connect"
msgstr "RFC 8414 / OpenID Connect"

msgid "Serve <code>/.well-known/openid-configuration</code> and <code>/.well-known/oauth-authorization-server</code>"
msgstr "Servir <code>/.well-known/openid-configuration</code> et <code>/.well-known/oauth-authorization-server</code>"

msgid "Minimal endpoint to pass the check. The <code>oauth/authorize</code> and <code>oauth/token</code> URLs are not actually implemented — declarative only."
msgstr "Endpoint minimaliste pour passer le check. Les URLs <code>oauth/authorize</code> et <code>oauth/token</code> ne sont pas réellement implémentées — déclaratif uniquement."

# ============================================================
# Section ⑥ WebMCP
# ============================================================

msgid "navigator.modelContext — API/MCP Discovery +1"
msgstr "navigator.modelContext — API/MCP Discovery +1"

msgid "Inject the WebMCP script into <code>wp_head</code>"
msgstr "Injecter le script WebMCP dans <code>wp_head</code>"

msgid "Registers the <strong>search</strong>, <strong>get_sitemap</strong> and <strong>get_homepage</strong> tools via <code>navigator.modelContext.provideContext()</code>. Extensible via <code>add_filter('supup_webmcp_tools', ...)</code>"
msgstr "Enregistre les outils <strong>search</strong>, <strong>get_sitemap</strong> et <strong>get_homepage</strong> via <code>navigator.modelContext.provideContext()</code>. Extensible via <code>add_filter('supup_webmcp_tools', ...)</code>"

