msgstr "Envoyer les headers HTTP <code>Link:</code> et injecter les balises <code>&lt;link&gt;</code> dans le <code>&lt;head&gt;</code>"

msgid "API Catalog"
msgstr "API Catalog"

msgid "Agent Skills"
msgstr "Agent Skills"

msgid "Service Doc"
msgstr "Service Doc"

msgid "Custom headers"
msgstr "Headers personnalisés"

